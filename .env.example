# Paths
INTEL_DB_PATH=./data/intel.db
INTEL_CACHE_DIR=./data/cache
INTEL_EXPORT_DIR=./data/exports
INTEL_BACKUP_DIR=./data/backups
INTEL_LOCK_DIR=./data/locks
INTEL_LOG_PATH=./data/intel.log

# HTTP
INTEL_USER_AGENT=intel-dashboard/0.1 (+local; lualducor@gmail.com)
INTEL_HTTP_TIMEOUT_SECONDS=15
INTEL_MAX_ITEMS_PER_PASS=0

# Paywall
INTEL_PAYWALL_PROXY_PREFIX=https://removepaywalls.com/

# Retention
INTEL_PRUNE_DAYS=180
INTEL_BACKUP_KEEP=30

# Queue thresholds
INTEL_THRESHOLD_MUST_READ=0.70
INTEL_THRESHOLD_MAYBE_USEFUL=0.40
INTEL_FEED_PAGE_SIZE=50

# Feedback
INTEL_FEEDBACK_COLD_FLOOR=0.3
INTEL_FEEDBACK_RAMP_AT_ACTIONS=50

# Display
INTEL_DISPLAY_TZ=America/Bogota
